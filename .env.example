# Copy to .env and fill in. Never commit .env.

# --- Expo client (EXPO_PUBLIC_* is embedded in the app bundle) ---
# Firebase Web SDK config — restrict abuse in Google Cloud Console (HTTP referrers / apps).
# Do NOT put service account JSON or OTP provider keys under EXPO_PUBLIC_*.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Public HTTP endpoints only (URLs, not secret keys)
EXPO_PUBLIC_API_URL=https://shootha-admin.onrender.com

# Optional
EXPO_PUBLIC_DEFAULT_PHONE_DIAL=+964
EXPO_PUBLIC_FIELD_OWNER_LINK_ID=

# Firebase App Check — Web (reCAPTCHA v3 site key, public)
EXPO_PUBLIC_RECAPTCHA_V3_SITE_KEY=
# App Check debug token for dev builds (register in Firebase Console → App Check → Debug)
EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# --- OTP Express server (Node only; load with dotenv — not bundled in Expo) ---
OTP_IQ_API_KEY=
PORT=4000
# Hops behind reverse proxy (Render/etc). Default production=1, development=0. Set "0" to disable explicitly.
TRUST_PROXY_HOPS=
# Production: comma-separated browser origins (required when NODE_ENV=production)
CORS_ORIGINS=
# Optional: enforce App Check JWT on /otp/* (requires firebase-admin + service account JSON)
OTP_ENFORCE_APP_CHECK=
# Single-line JSON service account (same Firebase project as the app)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Push notifications endpoint (server side)
# POST /send-notification uses Firestore users/{userId}.pushToken and sends via Expo Push API
# Required in production: include as x-api-key header when calling POST /send-notification
NOTIFICATION_API_KEY=
