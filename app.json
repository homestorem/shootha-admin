{
  "expo": {
    "name": "SHOOT'HA Business",
    "slug": "shoota-business",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-solid.png",
      "resizeMode": "cover",
      "backgroundColor": "#228B22"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shootha",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ar",
        "CFBundleAllowMixedLocalizations": false,
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00E676"
      },
      "package": "com.shootha.app",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "./plugins/withAndroidGradlePluginRepositories.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#00C853",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#228B22",
          "image": "./assets/splash-solid.png",
          "resizeMode": "cover"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "14beb36b-240f-4df8-9db2-40495009593b"
      }
    }
  }
}
